{# NAV-01..05 — recursive taxon tree (Phase 81 Plan 02; Plan 06 gap T3 fix).
   Input shape: a node with { rows: SpeciesRow[], children: Record<key, Node> }.
   Levels: 0=family, 1=subfamily, 2=tribe, 3=genus, 4=subgenus.
   Species are stored at the leaf (subgenus) node's `rows` array.

   NAV-02: at level 3 (genus), if the only subgenus key is 'null', render the
   species rows directly under the genus (skip the subgenus level). Otherwise
   render every subgenus key — including 'null' as a "no subgenus" leaf bucket.

   NAV-03 (Plan 06): clicks on family/genus/species rows are handled by
   bee-taxon-nav._onClick as IN-PLACE filter triggers (taxon-selected event
   + preventDefault). Cross-route deep-links to the SPA are provided by the
   species-card "View N occurrences →" button — NOT by anchors in the tree.
   Therefore family/genus/species rows render as <span class="taxon-label">,
   never as <a>. Subfamily and tribe ranks have no SPA representation either
   (src/url-state.ts only handles family|genus|species).

   Every <li> carries data-taxon and data-rank for bee-taxon-nav decoration
   (NAV-04 mute-not-hide). #}

{% macro renderSpecies(rows) %}
  {%- for sp in rows -%}
    <li data-taxon="{{ sp.scientificName }}" data-rank="species" role="treeitem"><span class="taxon-label">{{ sp.scientificName }}</span></li>
  {%- endfor -%}
{% endmacro %}

{# BL-04 + post-UAT extension: _data/species.js emits the literal 'null'
   sentinel at every taxon level (family/subfamily/tribe/genus/subgenus) when
   the source row lacks that rank. data-taxon must keep the raw key so URL
   state, click handlers, and tree keys stay aligned on a single sentinel;
   only the visible <summary> gets the human label. #}
{% macro nullLabel(rank) %}{% if rank == 'subgenus' %}(no subgenus){% elif rank == 'genus' %}(no genus){% elif rank == 'tribe' %}(no tribe){% elif rank == 'subfamily' %}(no subfamily){% else %}(no {{ rank }}){% endif %}{% endmacro %}

{% macro renderSubgenus(subgKey, subgNode) %}
  {%- set label = nullLabel('subgenus') if subgKey == 'null' else subgKey -%}
  <li data-taxon="{{ subgKey }}" data-rank="subgenus" role="treeitem" aria-expanded="false">
    <details>
      <summary>{{ label }}</summary>
      <ul role="group">{{ renderSpecies(subgNode.rows) }}</ul>
    </details>
  </li>
{% endmacro %}

{% macro renderGenus(name, node) %}
  {# NAV-02: subgenus-skip when 'null' is the sole key #}
  {%- set keys = node.children | dictsort -%}
  {%- set onlyNull = (keys | length == 1) and (node.children["null"] is defined) -%}
  {%- set label = nullLabel('genus') if name == 'null' else name -%}
  <li data-taxon="{{ name }}" data-rank="genus" role="treeitem" aria-expanded="false">
    <details>
      {%- if name == 'null' -%}
      <summary>{{ label }}</summary>
      {%- else -%}
      <summary><span class="taxon-label">{{ name }}</span></summary>
      {%- endif -%}
      <ul role="group">
        {%- if onlyNull -%}
          {{ renderSpecies(node.children["null"].rows) }}
        {%- else -%}
          {%- for subgKey, subgNode in keys -%}
            {{ renderSubgenus(subgKey, subgNode) }}
          {%- endfor -%}
        {%- endif -%}
      </ul>
    </details>
  </li>
{% endmacro %}

{% macro renderTribe(name, node) %}
  {%- set label = nullLabel('tribe') if name == 'null' else name -%}
  <li data-taxon="{{ name }}" data-rank="tribe" role="treeitem" aria-expanded="false">
    <details>
      <summary>{{ label }}</summary>
      <ul role="group">
        {%- for genKey, genNode in node.children | dictsort -%}
          {{ renderGenus(genKey, genNode) }}
        {%- endfor -%}
      </ul>
    </details>
  </li>
{% endmacro %}

{% macro renderSubfamily(name, node) %}
  {%- set label = nullLabel('subfamily') if name == 'null' else name -%}
  <li data-taxon="{{ name }}" data-rank="subfamily" role="treeitem" aria-expanded="false">
    <details>
      <summary>{{ label }}</summary>
      <ul role="group">
        {%- for triKey, triNode in node.children | dictsort -%}
          {{ renderTribe(triKey, triNode) }}
        {%- endfor -%}
      </ul>
    </details>
  </li>
{% endmacro %}

{% macro renderFamily(name, node) %}
  {%- set label = nullLabel('family') if name == 'null' else name -%}
  <li data-taxon="{{ name }}" data-rank="family" role="treeitem" aria-expanded="false">
    <details>
      {%- if name == 'null' -%}
      <summary>{{ label }}</summary>
      {%- else -%}
      <summary><span class="taxon-label">{{ name }}</span></summary>
      {%- endif -%}
      <ul role="group">
        {%- for subKey, subNode in node.children | dictsort -%}
          {{ renderSubfamily(subKey, subNode) }}
        {%- endfor -%}
      </ul>
    </details>
  </li>
{% endmacro %}

{# renderNode is the generic dispatcher exposed for tests/inspection;
   the macros above implement each level. #}
{% macro renderNode(name, node, level) %}
  {%- if level == 0 -%}{{ renderFamily(name, node) }}
  {%- elif level == 1 -%}{{ renderSubfamily(name, node) }}
  {%- elif level == 2 -%}{{ renderTribe(name, node) }}
  {%- elif level == 3 -%}{{ renderGenus(name, node) }}
  {%- endif -%}
{% endmacro %}

{% macro renderTree(tree) %}
<bee-taxon-nav>
  <ul class="taxon-tree-root" role="tree" aria-label="Species taxonomy">
    {%- for famKey, famNode in tree.children | dictsort -%}
      {{ renderNode(famKey, famNode, 0) }}
    {%- endfor -%}
  </ul>
</bee-taxon-nav>
{% endmacro %}
