{
  "name": "beeatlas",
  "private": true,
  "version": "0.0.0",
  "description": "",
  "homepage": "https://github.com/rainhead/beeatlas#readme",
  "bugs": {
    "url": "https://github.com/rainhead/beeatlas/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rainhead/beeatlas.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "predev": "node scripts/make-local-manifest.js",
    "dev": "eleventy --serve",
    "validate-species": "node scripts/validate-species.mjs",
    "validate-db": "node scripts/validate-db.mjs",
    "validate-bundle-size": "node scripts/validate-bundle-size.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:validate-links": "lychee --config lychee.toml --root-dir _site '_site/**/*.html'",
    "build": "npm run validate-species && npm run validate-db && npm run typecheck && eleventy && npm run validate-bundle-size",
    "preview": "vite preview --outDir _site",
    "smoke": "node scripts/smoke-boot.mjs",
    "fetch-data": "bash scripts/fetch-data.sh",
    "pull-published": "bash scripts/pull-published.sh",
    "measure-lcp": "bash scripts/measure-lcp.sh"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-plugin-vite": "^8.0.0",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24.13.3",
    "acorn": "^8.17.0",
    "happy-dom": "^20.10.6",
    "hyparquet": "^1.26.2",
    "mapshaper": "^0.7.44",
    "playwright": "^1.61.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "lit": "^3.3.3",
    "mapbox-gl": "^3.26.0",
    "vite-plugin-pwa": "^1.3.0",
    "wa-sqlite": "^1.0.0",
    "workbox-build": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-window": "^7.4.1"
  }
}
