{
  "name": "beeatlas",
  "private": true,
  "version": "0.0.0",
  "description": "",
  "homepage": "https://github.com/rainhead/beeatlas#readme",
  "bugs": {
    "url": "https://github.com/rainhead/beeatlas/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rainhead/beeatlas.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "predev": "node scripts/make-local-manifest.js",
    "dev": "eleventy --serve",
    "build:data": "cd data && uv run python run.py",
    "validate-species": "node scripts/validate-species.mjs",
    "validate-db": "node scripts/validate-db.mjs",
    "validate-bundle-size": "node scripts/validate-bundle-size.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:validate-links": "lychee --config lychee.toml --root-dir _site '_site/**/*.html'",
    "build": "npm run validate-species && npm run validate-db && npm run typecheck && eleventy && npm run validate-bundle-size",
    "preview": "vite preview --outDir _site",
    "fetch-data": "bash scripts/fetch-data.sh",
    "measure-lcp": "bash scripts/measure-lcp.sh"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-plugin-vite": "^7.1.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^22.13.14",
    "happy-dom": "^20.8.9",
    "hyparquet": "^1.26.0",
    "mapshaper": "^0.7.16",
    "typescript": "^5.8.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "lit": "^3.2.1",
    "mapbox-gl": "^3.22.0",
    "wa-sqlite": "^1.0.0"
  }
}
