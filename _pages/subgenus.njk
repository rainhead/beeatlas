---
pagination:
  data: species.subgenusList
  size: 1
  alias: subgenus
permalink: "/species/{{ subgenus.genus }}/{{ subgenus.subgenus }}/"
eleventyComputed:
  title: "{{ subgenus.subgenus }} ({{ subgenus.genus }}) — BeeAtlas"
layout: default.njk
---
<article class="taxon-page">
  <nav class="breadcrumb">
    {{ subgenus.family }}<span class="sep">/</span><a href="/species/{{ subgenus.genus }}/index.html">{{ subgenus.genus }}</a><span class="sep">/</span>{{ subgenus.subgenus }}
  </nav>
  <h1><em>{{ subgenus.subgenus }}</em></h1>
  <p class="metadata">{{ subgenus.speciesCount | quantify("species", "species") }} · {{ subgenus.totalOccurrences | quantify("record") }}</p>
  <div class="media-grid">
    <img loading="lazy"
         src="/data/species-maps/subgenus/{{ subgenus.genus }}/{{ subgenus.subgenus }}.svg"
         alt="Occurrence map for subgenus {{ subgenus.subgenus }} ({{ subgenus.genus }})"
         style="aspect-ratio: 15/8; width: 100%;">
    {%- if subgenus.speciesCount > 0 -%}
    <ul class="species-list">
    {%- for sp in subgenus.species -%}
      <li>
        <span class="swatch" style="background: {{ sp.hexColor }};" aria-hidden="true"></span>
        {%- if sp.slug %}<a href="/species/{{ sp.slug }}/index.html"><em>{{ sp.scientificName }}</em></a>{%- else %}<em>{{ sp.scientificName }}</em>{%- endif %}
        {%- if sp.occurrence_count > 0 -%}
        <span class="count">{{ sp.specimen_count | quantify("specimen") }} · {{ sp.inat_obs_count | quantify("community observation") }}</span>
        {%- elif sp.on_checklist -%}
        <span class="count">{{ sp.checklist_count | quantify("checklist record") }}</span>
        {%- else -%}
        <span class="count">{{ 0 | quantify("record") }}</span>
        {%- endif -%}
      </li>
    {%- endfor -%}
    </ul>
    {%- endif -%}
  </div>
  {%- if subgenus.taxon_id -%}
  <a class="taxon-action" href="https://www.inaturalist.org/taxa/{{ subgenus.taxon_id }}">View on iNaturalist →</a>
  {%- endif -%}
</article>
<script type="module" src="/src/entries/taxon-page.ts"></script>
