---
pagination:
  data: collectors.collectorsArray
  size: 1
  alias: collector
permalink: "/collectors/{{ collector.login | urlencode }}/index.html"
eleventyComputed:
  title: "{{ collector.display_name }} — BeeAtlas"
layout: default.njk
---
<link rel="stylesheet" href="/src/styles/places.css">
{%- if collector.atom_feed_url %}<link rel="alternate" type="application/atom+xml" title="{{ collector.display_name }} — recent determinations" href="{{ collector.atom_feed_url }}">{% endif %}
{#- Phase 172 GC2: per-collector CSS highlight blocks.
    Scope by .coverage-county / .coverage-eco wrapper class so the two maps
    don't cross-highlight each other (both use [data-region] attribute selectors).
    Specificity of .coverage-county [data-region="…"] (0,1,1,0) beats .region
    (0,1,0,0) in the inlined SVG's own <style>, so highlights always win.
-#}
{%- if collector.county_names and collector.county_names.length > 0 -%}
<style>
{% for c in collector.county_names %}.coverage-county [data-region="{{ c }}"]{% if not loop.last %},
{% endif %}{% endfor %} { fill: #b0cfe8; }
</style>
{%- endif -%}
{%- if collector.ecoregion_names and collector.ecoregion_names.length > 0 -%}
<style>
{% for e in collector.ecoregion_names %}.coverage-eco [data-region="{{ e }}"]{% if not loop.last %},
{% endif %}{% endfor %} { fill: #b0cfe8; }
</style>
{%- endif -%}
<article class="places-page place-detail">
  <h1>{{ collector.display_name }}</h1>
  <p class="metadata">{{ collector.specimen_count | quantify("specimen") }} · {{ collector.sample_count | quantify("sample") }} · {{ collector.species_count | quantify("species", "species") }}</p>
  {%- if collector.active_since -%}
  <p class="metadata">Active since {{ collector.active_since }} ({{ collector.seasons_count | quantify("season") }})</p>
  {%- endif -%}
  {%- if collector.status_denominator > 0 -%}
  <p class="status-split">{{ collector.status_identified }} identified to species, {{ collector.status_awaiting }} awaiting ID</p>
  {%- endif -%}
  {%- if collector.recordedBy or collector.host_inat_login -%}
  {#- Guard: a both-null collector would render `?collectors=:`, which url-state.ts discards,
      silently showing ALL occurrences instead of this collector's (CR-02). 0 such collectors
      today, but the guard keeps the link honest if a name-less waba_specimen-only one appears. -#}
  <a href="/?collectors={{ collector.recordedBy | urlencode }}:{{ collector.host_inat_login | urlencode }}">View on the atlas →</a>
  {%- endif -%}
  {#- Phase 172 GC2: Inline shared base maps with per-collector CSS highlight.
      Replaced per-collector <img src="/data/collector-maps/..."> (248 files, ~122 MB)
      with two committed SVG partials highlighted per-collector via <style> blocks above.
      The wrapping div carries role="img" aria-label="..." for accessibility since the
      inline SVG has aria-hidden="true" (it's decorative — the label carries the info). -#}
  {%- if collector.county_count > 0 or collector.ecoregion_count > 0 -%}
  <section class="coverage-section">
    <div class="coverage-maps">
      {%- if collector.county_count > 0 -%}
      <div class="map-block coverage-county"
           role="img"
           aria-label="County coverage map for {{ collector.display_name }} — {{ collector.county_count | quantify('county', 'counties') }}">
        {% include "maps/counties-base.svg" %}
        <p class="metadata">{{ collector.county_count | quantify("county", "counties") }}</p>
      </div>
      {%- endif -%}
      {%- if collector.ecoregion_count > 0 -%}
      <div class="map-block coverage-eco"
           role="img"
           aria-label="Ecoregion coverage map for {{ collector.display_name }} — {{ collector.ecoregion_count | quantify('ecoregion') }}">
        {% include "maps/ecoregions-base.svg" %}
        <p class="metadata">{{ collector.ecoregion_count | quantify("ecoregion") }}</p>
      </div>
      {%- endif -%}
    </div>
  </section>
  {%- endif -%}
  {#- Species list: uses sp.name (cased scientificName) + sp.count (atlas records of
      that species), rendered as "— N specimens" (operator chose the explicit unit). -#}
  {%- if collector.species_by_genus and collector.species_by_genus.length > 0 -%}
  <section class="species-section">
    <h2>Species collected</h2>
    <div class="species-by-genus">
    {%- for genus_group in collector.species_by_genus -%}
      <div class="genus-section">
        <h3 class="genus-heading"><em>{{ genus_group.genus }}</em></h3>
        <ul class="species-list">
        {%- for sp in genus_group.species -%}
          <li>
            <a href="/species/{{ sp.slug }}/">{{ sp.name }}</a> <span class="species-count">— {{ sp.count | quantify("specimen") }}</span>
          </li>
        {%- endfor -%}
        </ul>
      </div>
    {%- endfor -%}
    </div>
  </section>
  {%- endif -%}
  {#- Phase 171: Event feed section (STREAM-01/02/03) -#}
  {%- if collector.total_event_count > 0 -%}
  <section class="event-feed-section">
    <h2>Recently identified specimens{%- if collector.atom_feed_url %} <a class="feed-link" type="application/atom+xml" href="{{ collector.atom_feed_url }}">Subscribe to recent determinations</a>{% endif %}</h2>
    <div class="event-feed-wrap">
    <table class="event-feed">
      <thead>
        <tr>
          <th scope="col">Date</th>
          <th scope="col">Catalog</th>
          <th scope="col">Event</th>
          <th scope="col">Taxon</th>
          <th scope="col">Determiner</th>
        </tr>
      </thead>
      <tbody>
      {%- for event in collector.first_page_events -%}
      {%- if event.event_type == 'Collected' -%}
      <tr class="event-row{%- if event.is_pending %} event-row--pending{% endif %}">
        <td class="event-date"><time datetime="{{ event.event_date }}">{{ event.event_date }}</time></td>
        <td class="event-catalog">{%- if event.ecdysis_id %}<a href="https://ecdysis.org/collections/individual/index.php?occid={{ event.ecdysis_id }}" title="{{ event.catalog_number }}">{{ event.catalog_number | replace("WSDA_", "") }}</a>{% endif %}</td>
        <td class="event-type event-type--collected">Collected</td>
        <td class="event-taxon">
          {%- if event.species_slug and not event.is_pending %}<a href="/species/{{ event.species_slug }}/">{{ event.species_name }}</a>
          {%- elif event.inat_url and not event.is_pending %}<a href="{{ event.inat_url }}" rel="external" class="event-taxon--external">{{ event.species_name }}</a>
          {%- else %}{{ event.species_name }}{% endif %}
          {%- if event.is_pending %} <span class="event-pending">awaiting ID</span>{% endif %}
        </td>
        <td class="event-determiner"></td>
      </tr>
      {%- else -%}
      {%- set id_type_class = 'event-type--identified' if event.is_current else 'event-type--reidentified' -%}
      {%- set id_label = 'Re-identified' if event.is_reidentification else 'Identified' -%}
      <tr class="event-row{%- if event.is_reidentification %} event-row--reidentified{% endif %}">
        <td class="event-date"><time datetime="{{ event.event_date }}">{{ event.event_date }}</time></td>
        <td class="event-catalog">{%- if event.ecdysis_id %}<a href="https://ecdysis.org/collections/individual/index.php?occid={{ event.ecdysis_id }}" title="{{ event.catalog_number }}">{{ event.catalog_number | replace("WSDA_", "") }}</a>{% endif %}</td>
        <td class="event-type {{ id_type_class }}">{{ id_label }}</td>
        <td class="event-taxon">
          {%- if event.species_slug %}<a href="/species/{{ event.species_slug }}/">{{ event.species_name }}</a>
          {%- elif event.inat_url %}<a href="{{ event.inat_url }}" rel="external" class="event-taxon--external">{{ event.species_name }}</a>
          {%- else %}{{ event.species_name }}{% endif %}
        </td>
        <td class="event-determiner">{%- if event.determiner %}by {{ event.determiner }}{% endif %}</td>
      </tr>
      {%- endif -%}
      {%- endfor -%}
      </tbody>
    </table>
    </div>
    {%- if collector.total_event_pages > 1 -%}
    <nav class="event-pagination" aria-label="Event history pages">
      <a href="/collectors/{{ collector.login | urlencode }}/page/2/index.html">Older events →</a>
    </nav>
    {%- endif -%}
  </section>
  {%- else -%}
  <section class="event-feed-section">
    <h2>Collection history{%- if collector.atom_feed_url %} <a class="feed-link" type="application/atom+xml" href="{{ collector.atom_feed_url }}">Subscribe to recent determinations</a>{% endif %}</h2>
    <p class="metadata">No specimen events recorded yet.</p>
  </section>
  {%- endif -%}
</article>
