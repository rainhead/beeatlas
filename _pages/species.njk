---
layout: default.njk
permalink: /species/index.html
title: Species — BeeAtlas
---
{% from "taxon-tree.njk" import renderTree %}
{{ renderTree(species.tree) }}
<bee-species-page>
<bee-species-filter
  data-county-options='{{ species.counties | dump | safe }}'
  data-ecoregion-options='{{ species.ecoregionL3 | dump | safe }}'
></bee-species-filter>
<div class="breadcrumb-pills"></div>
<div class="empty-state" hidden>
  No species match these filters.
  <button type="button" class="clear-filters">Clear filters</button>
</div>
{%- for sp in species.flat -%}
{# BL-01: data-* taxon ancestors let the coordinator gate cards by
   _activeTaxonPath without a sidecar JSON. 'null' is the canonical
   no-subgenus sentinel (BL-04, matches _data/species.js tree key). #}
<bee-species-card
  data-family="{{ sp.family }}"
  data-subfamily="{{ sp.subfamily }}"
  data-tribe="{{ sp.tribe }}"
  data-genus="{{ sp.genus }}"
  data-subgenus="{% if sp.subgenus %}{{ sp.subgenus }}{% else %}null{% endif %}"
>
  <h2>{{ sp.scientificName }}</h2>
  {%- set photoEntry = photos[sp.scientificName] -%}
  {%- if photoEntry and photoEntry.photos and photoEntry.photos.length > 0 -%}
    {%- set p = photoEntry.photos[0] -%}
    <img loading="lazy" src="{{ p.url }}" alt="{{ sp.scientificName }}">
    <p class="attribution">{{ p.attribution }}</p>
  {%- endif -%}
  {%- if sp.occurrence_count > 0 -%}
    <img loading="lazy" src="/data/species-maps/{{ sp.slug }}.svg" alt="Occurrence map for {{ sp.scientificName }}">
  {%- endif -%}
  {%- if photoEntry and photoEntry.description -%}
    <p class="description">{{ photoEntry.description }}</p>
  {%- endif -%}
  <span class="count-badge">{{ sp.occurrence_count }} records</span>
  <seasonality-viz></seasonality-viz>
  <a class="spa-link" href="/?taxon={{ sp.scientificName | urlencode }}&taxonRank=species">View {{ sp.occurrence_count }} occurrences →</a>
</bee-species-card>
{%- endfor -%}
</bee-species-page>
<script type="module" src="/src/entries/species.ts"></script>
