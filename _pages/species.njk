---
layout: default.njk
permalink: /species/index.html
title: Species — BeeAtlas
---
{%- macro renderNode(node) -%}
{%- if node.rank === "species" -%}
<li data-rank="species" data-name="{{ node.scientificName | lower }}">
  <a class="node-name" href="/species/{{ node.slug }}/"><em>{{ node.scientificName }}</em></a>
  <span class="node-counts">{{ node.specimen_count | quantify("specimen") }} · {{ node.inat_obs_count | quantify("community observation") }}</span>
  <a class="node-map" href="/?taxon={{ node.scientificName | urlencode }}&amp;taxonRank=species" aria-label="Map: {{ node.scientificName }} occurrences">Map</a>
</li>
{%- elif node.rank === "family" -%}
<details class="tree-node tree-node--family" data-rank="family" data-name="{{ node.name | lower }}">
  <summary>
    <span class="node-name">{{ node.name }}</span>
    <span class="node-counts">{{ node.specimen_count | quantify("specimen") }} · {{ node.inat_obs_count | quantify("community observation") }}</span>
    <a class="node-map" href="/?taxon={{ node.name | urlencode }}&amp;taxonRank=family" aria-label="Map: {{ node.name }} occurrences">Map</a>
  </summary>
  {%- for child in node.children -%}
  {{ renderNode(child) }}
  {%- endfor -%}
</details>
{%- elif node.rank === "genus" -%}
<details class="tree-node tree-node--genus" data-rank="genus" data-name="{{ node.name | lower }}">
  <summary>
    <a class="node-name" href="/species/{{ node.name }}/"><em>{{ node.name }}</em></a>
    <span class="node-counts">{{ node.specimen_count | quantify("specimen") }} · {{ node.inat_obs_count | quantify("community observation") }}</span>
    <a class="node-map" href="/?taxon={{ node.name | urlencode }}&amp;taxonRank=genus" aria-label="Map: {{ node.name }} occurrences">Map</a>
  </summary>
  {%- if node.children | length > 0 and node.children[0].rank === "species" -%}
  <ul class="species-list">
    {%- for child in node.children -%}
    {{ renderNode(child) }}
    {%- endfor -%}
  </ul>
  {%- else -%}
  {%- for child in node.children -%}
  {{ renderNode(child) }}
  {%- endfor -%}
  {%- endif -%}
</details>
{%- elif node.rank === "subgenus" -%}
<details class="tree-node tree-node--subgenus" data-rank="subgenus" data-name="{{ node.name | lower }}">
  <summary>
    <a class="node-name" href="/species/{{ node.genusName }}/{{ node.name }}/"><em>{{ node.name }}</em></a>
    <span class="node-counts">{{ node.specimen_count | quantify("specimen") }} · {{ node.inat_obs_count | quantify("community observation") }}</span>
    <a class="node-map" href="/?taxon={{ node.name | urlencode }}&amp;taxonRank=subgenus" aria-label="Map: {{ node.name }} occurrences">Map</a>
  </summary>
  {%- if node.children | length > 0 and node.children[0].rank === "species" -%}
  <ul class="species-list">
    {%- for child in node.children -%}
    {{ renderNode(child) }}
    {%- endfor -%}
  </ul>
  {%- else -%}
  {%- for child in node.children -%}
  {{ renderNode(child) }}
  {%- endfor -%}
  {%- endif -%}
</details>
{%- elif node.rank === "tribe" -%}
<details class="tree-node tree-node--tribe" data-rank="tribe" data-name="{{ node.name | lower }}">
  <summary>
    <a class="node-name" href="/species/tribe/{{ node.name }}/"><em>{{ node.name }}</em></a>
    <span class="node-counts">{{ node.specimen_count | quantify("specimen") }} · {{ node.inat_obs_count | quantify("community observation") }}</span>
    <a class="node-map" href="/?taxon={{ node.name | urlencode }}&amp;taxonRank=tribe" aria-label="Map: {{ node.name }} occurrences">Map</a>
  </summary>
  {%- for child in node.children -%}
  {{ renderNode(child) }}
  {%- endfor -%}
</details>
{%- elif node.rank === "subfamily" -%}
<details class="tree-node tree-node--subfamily" data-rank="subfamily" data-name="{{ node.name | lower }}">
  <summary>
    <a class="node-name" href="/species/subfamily/{{ node.name }}/"><em>{{ node.name }}</em></a>
    <span class="node-counts">{{ node.specimen_count | quantify("specimen") }} · {{ node.inat_obs_count | quantify("community observation") }}</span>
    <a class="node-map" href="/?taxon={{ node.name | urlencode }}&amp;taxonRank=subfamily" aria-label="Map: {{ node.name }} occurrences">Map</a>
  </summary>
  {%- for child in node.children -%}
  {{ renderNode(child) }}
  {%- endfor -%}
</details>
{%- endif -%}
{%- endmacro -%}
<article class="taxon-page species-index">
  <h1>Species</h1>
  <div class="species-index-controls">
    <input type="search" id="species-filter"
           aria-label="Filter taxa"
           placeholder="Filter taxa…"
           autocomplete="off">
    <label class="rank-toggle-label">
      <input type="checkbox" id="show-all-ranks">
      Show all ranks
    </label>
  </div>
  <p id="filter-empty" hidden role="status">No taxa match "<span id="filter-query"></span>".</p>
  {%- for family in species.fullTree -%}
  {{ renderNode(family) }}
  {%- endfor -%}
</article>
<script type="module" src="/src/entries/species-index.ts"></script>
