---
pagination:
  data: species.subfamilyList
  size: 1
  alias: subfamily
permalink: "/species/subfamily/{{ subfamily.subfamily }}/"
eleventyComputed:
  title: "{{ subfamily.subfamily }} — BeeAtlas"
layout: default.njk
---
<article class="taxon-page">
  <nav class="breadcrumb">
    {{ subfamily.family }}<span class="sep">/</span>{{ subfamily.subfamily }}
  </nav>
  <h1>{{ subfamily.subfamily }}</h1>
  <p class="metadata">
    {%- if subfamily.tribesCount > 0 -%}{{ subfamily.tribesCount | quantify("tribe") }} · {% endif %}{{ subfamily.generaCount | quantify("genus", "genera") }} · {{ subfamily.totalOccurrences | quantify("record") }}
  </p>
  <div class="media-grid">
    <img loading="lazy"
         src="/data/species-maps/subfamily/{{ subfamily.subfamily }}.svg"
         alt="Occurrence map for subfamily {{ subfamily.subfamily }}"
         style="aspect-ratio: 15/8; width: 100%;">
    {# Single grid child so .media-grid stays 2-column (map | members); #}
    {# tribe sections stack vertically inside it. #}
    <div class="taxon-members">
    {%- if subfamily.tribes.length > 0 -%}
    {# D-04: nested tribes->genera layout #}
    {%- for t in subfamily.tribes -%}
    <h2><a href="/species/tribe/{{ t.tribe }}/index.html">{{ t.tribe }}</a></h2>
    <ul class="species-list">
      {%- for g in t.genera -%}
      <li>
        <span class="swatch" style="background: {{ g.hexColor }};" aria-hidden="true"></span>
        <a href="/species/{{ g.genus }}/index.html"><em>{{ g.genus }}</em></a>
        <span class="count">{{ g.specimen_count | quantify("specimen") }} · {{ g.inat_obs_count | quantify("community observation") }}</span>
      </li>
      {%- endfor -%}
    </ul>
    {%- endfor -%}
    {%- else -%}
    {# D-05: tribe-less subfamily — flat genus list with no tribe heading #}
    <ul class="species-list">
      {%- for g in subfamily.genera -%}
      <li>
        <span class="swatch" style="background: {{ g.hexColor }};" aria-hidden="true"></span>
        <a href="/species/{{ g.genus }}/index.html"><em>{{ g.genus }}</em></a>
        <span class="count">{{ g.specimen_count | quantify("specimen") }} · {{ g.inat_obs_count | quantify("community observation") }}</span>
      </li>
      {%- endfor -%}
    </ul>
    {%- endif -%}
    </div>
  </div>
  {%- if subfamily.taxon_id -%}
  <a class="taxon-action" href="/?taxon={{ subfamily.taxon_id }}">View on atlas →</a>
  <a class="taxon-action" href="https://www.inaturalist.org/taxa/{{ subfamily.taxon_id }}">View on iNaturalist →</a>
  {%- endif -%}
</article>
<script type="module" src="/src/entries/taxon-page.ts"></script>
