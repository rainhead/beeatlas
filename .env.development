# Loaded by Vite ONLY in dev mode (`npm run dev`) — production builds
# (deploy.yml CI, local `npm run build`) never read this file, so the
# deployed bundle always points at the real API.
#
# Points the auth client (src/auth-client.ts) at a locally-running write
# API (api/serve.py on port 8081 — see api/README.md for the full local
# auth loop, including the dev iNat app registration).
VITE_NOTES_API_BASE_URL=http://localhost:8081
