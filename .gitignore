.vuepress/dist

# vuepress v2.x temp and cache directory
.temp
.cache

# vitepress build output
**/.vitepress/dist

# vitepress cache directory
**/.vitepress/cache

# Docusaurus cache and generated files
.docusaurus

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# yarn v2
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

*.parquet
/public/data/*
# v3.7 PPIPE-05: commit places.geojson + places.json so CI builds without running the pipeline
!/public/data/places.geojson
!/public/data/places.json
# v6.0 PAGE-01: commit collectors.json so npm test / build pass on a clean checkout
!/public/data/collectors.json
# v6.0 STREAM-03: commit collector_event_pages.json so CI build generates event sub-pages
!/public/data/collector_event_pages.json

# dbt runtime artifacts (generated by dbt build; never commit)
data/dbt/target/
data/dbt/logs/
data/dbt/dbt_packages/
data/dbt/.user.yml

# Claude Code worktrees (temporary isolated repo copies for agent execution)
.claude/worktrees/

# Claude Code runtime files (lock files, cached state)
.claude/*.lock

# Local agent/tool scratch dirs (per-checkout, not project artifacts)
.agents/
.claire/
.claude/skills/

# Session handoff notes (transient, written by /gsd-pause-work etc.)
.continue-here.md

# GSD debug session artifacts
.planning/debug/

# DEM tile cache (~200-500 MB WA DEM file)
data/_dem_cache/
.aider*

# Playwright MCP scratch (screenshots, snapshots, console logs)
.playwright-mcp/

# lychee link-checker cache
.lycheecache
